# Database
POSTGRES_USER=cloudops
POSTGRES_PASSWORD=cloudops_secret
POSTGRES_DB=cloudops
DATABASE_URL=postgresql://cloudops:cloudops_secret@postgres:5432/cloudops

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
